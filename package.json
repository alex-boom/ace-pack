{
  "name": "ace-pack",
  "version": "3.5.0",
  "description": "Local AgentOps for AI coding agents: durable memory, guardrails, and quality gates for vibe coding in real repositories.",
  "type": "module",
  "license": "MIT",
  "author": "Alexandr Dudka <dudka.alexandr83@gmail.com>",
  "homepage": "https://github.com/alex-boom/ace-pack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-boom/ace-pack.git"
  },
  "bugs": {
    "url": "https://github.com/alex-boom/ace-pack/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "agentops",
    "agentic",
    "agent-memory",
    "context-management",
    "cognitive-architecture",
    "ai-coding",
    "vibe-coding",
    "developer-tools",
    "guardrails",
    "cursor",
    "claude-code",
    "codex",
    "mcp",
    "mcp-server",
    "mcp-client",
    "aider",
    "github-copilot",
    "chatgpt",
    "cursor-rules",
    "cli"
  ],
  "files": [
    "README.md",
    "logo.svg",
    "logo-npm.svg",
    "*.cmd",
    "*.mjs",
    "scripts/*.mjs"
  ],
  "bin": {
    "ace-pack": "install-ace-pack.mjs",
    "agent-memory-pack": "install-agent-memory-pack.mjs"
  },
  "scripts": {
    "install:pack": "node ./install-ace-pack.mjs",
    "install:legacy": "node ./install-agent-memory-pack.mjs",
    "link:global": "npm link",
    "build:npm-package": "node ./tools/build-npm-package.mjs",
    "check:npm-payload": "npm run build:npm-package && node ./tools/check-npm-payload.mjs",
    "preview:npm": "npm run build:npm-package && npm pack ./.npm-publish --dry-run",
    "publish:npm:dry": "npm run build:npm-package && npm publish ./.npm-publish --dry-run",
    "publish:npm": "npm run build:npm-package && npm publish ./.npm-publish",
    "release:npm:dry": "npm run check:npm-payload && npm run preview:npm && npm run publish:npm:dry",
    "release:npm": "npm run check:npm-payload && npm run preview:npm && npm run publish:npm",
    "release:ready": "npm run typecheck && npm run lint && npm run test && npm run smoke:fake-project && npm run ace -- gate && npm run check:npm-payload && npm run release:npm:dry",
    "smoke:fake-project": "node ./tools/smoke-fake-project.mjs",
    "dogfood:self-check": "node ./tools/dogfood-self-check.mjs",
    "ace": "node ./scripts/ace-cli.mjs",
    "ace:validate": "npm run typecheck && npm run lint && npm run test",
    "test": "vitest run",
    "typecheck": "node ./tools/check-js-syntax.mjs",
    "lint": "node ./tools/check-line-limit.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
